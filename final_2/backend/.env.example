# 默认使用本地 mock 分析，便于无密钥环境下演示项目。
LLM_PROVIDER=mock
LLM_ENABLE_CACHE=true

# 如需启用 DeepSeek / OpenAI-compatible 接口，取消下面几行注释并填写真实密钥。
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_llm_api_key
# LLM_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-v4

# 可选：后端启动配置。
# NIGHTSENSE_OUTPUT_DIR=outputs\beijing_tdrive
# FLASK_DEBUG=0
# PORT=5000
